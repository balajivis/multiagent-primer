#!/usr/bin/env node
// task — atomic task allocator for Lab 5 (extends Lab 2's CLI with `fail` + `requires`).
//
// commands:
//   task list   [--mine agent-N] [--open]
//   task claim  <id> --as agent-N
//   task done   <id> --as agent-N --result "<summary>"
//   task fail   <id> --as agent-N --lesson "<one-line gotcha>"
//   task lessons [--for <tag>]            # recent failure lessons (stigmergic read)
//   task add    "<title>" --requires <tag,tag> [--estimate N]
//   task status

const fs   = require('fs');
const path = require('path');

const FILE = path.resolve(__dirname, '..', 'tasks.json');
const LOCK = FILE + '.lock';

// ── atomic lock via O_EXCL — POSIX-portable, no flock needed ──────────────
function withLock(fn) {
  const start = Date.now();
  while (true) {
    try {
      const fd = fs.openSync(LOCK, 'wx');
      try { return fn(); }
      finally { try { fs.closeSync(fd); } catch {} fs.unlinkSync(LOCK); }
    } catch (e) {
      if (e.code !== 'EEXIST') throw e;
      if (Date.now() - start > 3000) throw new Error('lock timeout — a previous run may have crashed; rm ' + LOCK);
      const ms = 20 + Math.floor(Math.random() * 30);
      const until = Date.now() + ms;
      while (Date.now() < until) {}
    }
  }
}

function loadTasks() {
  if (!fs.existsSync(FILE)) {
    console.error(`tasks.json not found at ${FILE}`);
    console.error(`run ./lab5-up.sh to seed it from tasks.template.json`);
    process.exit(2);
  }
  return JSON.parse(fs.readFileSync(FILE, 'utf8'));
}
function saveTasks(data) {
  data.version++;
  fs.writeFileSync(FILE, JSON.stringify(data, null, 2) + '\n');
}
function findTask(data, id) {
  const t = data.tasks.find(x => x.id === id);
  if (!t) throw new Error(`task ${id} not found`);
  return t;
}
function reqs(t) { return t.requires || t.needs || []; }

function flag(name, args) {
  const i = args.indexOf('--' + name);
  return i >= 0 ? args[i + 1] : null;
}
function has(name, args) { return args.includes('--' + name); }

const [cmd, ...rest] = process.argv.slice(2);

const COLORS = {
  open: '\x1b[36m', claimed: '\x1b[33m', done: '\x1b[32m', failed: '\x1b[31m',
  dim: '\x1b[2m', reset: '\x1b[0m', bold: '\x1b[1m',
};
function col(s, c) { return process.stdout.isTTY ? COLORS[c] + s + COLORS.reset : s; }

function cmdList() {
  const data = loadTasks();
  const mine = flag('mine', rest);
  const onlyOpen = has('open', rest);
  for (const t of data.tasks) {
    if (mine && t.claimed_by !== mine) continue;
    if (onlyOpen && t.status !== 'open') continue;
    const status  = t.status.padEnd(8);
    const tags    = reqs(t).join(',');
    const owner   = t.claimed_by ? ` · ${t.claimed_by}` : '';
    const lessonF = t.lessons ? col(' 📓', 'dim') : '';
    console.log(`${col(t.id, 'dim')}  ${col(status, t.status)}  ${col(tags.padEnd(22), 'dim')}  ${t.title}${col(owner, 'dim')}${lessonF}`);
  }
}

function cmdClaim() {
  const id = rest[0];
  const agent = flag('as', rest);
  if (!id || !agent) { console.error('usage: task claim <id> --as agent-N'); process.exit(2); }
  const r = withLock(() => {
    const data = loadTasks();
    const t = findTask(data, id);
    if (t.status !== 'open') {
      return { ok:false, msg: col(`✗ ${id} is ${t.status}` + (t.claimed_by ? ` by ${t.claimed_by}` : ''), 'claimed') };
    }
    t.status = 'claimed'; t.claimed_by = agent; t.claimed_at = new Date().toISOString();
    saveTasks(data);
    return { ok:true, task: t };
  });
  if (!r.ok) { console.error(r.msg); process.exit(1); }
  console.log(col(`✓ ${id} claimed by ${agent}`, 'done'));
  const tags = reqs(r.task);
  if (tags.length) console.log(col(`  requires: ${tags.join(', ')} — verify you have these capabilities`, 'dim'));
  console.log(col(`  output → ${r.task.output}`, 'dim'));
  if (r.task.lessons) console.log(col(`  📓 lesson on file: ${r.task.lessons}`, 'failed'));
}

function cmdDone() {
  const id = rest[0];
  const agent = flag('as', rest);
  const result = flag('result', rest) || 'done';
  if (!id || !agent) { console.error('usage: task done <id> --as agent-N --result "summary"'); process.exit(2); }
  const r = withLock(() => {
    const data = loadTasks();
    const t = findTask(data, id);
    if (t.status !== 'claimed') return { ok:false, msg: `✗ ${id} is ${t.status}` };
    if (t.claimed_by !== agent)  return { ok:false, msg: `✗ ${id} claimed by ${t.claimed_by}, not ${agent}` };
    t.status = 'done'; t.completed_at = new Date().toISOString(); t.result = result;
    saveTasks(data);
    return { ok:true };
  });
  if (!r.ok) { console.error(r.msg); process.exit(1); }
  console.log(col(`✓ ${id} done by ${agent}`, 'done'));
}

function cmdFail() {
  const id = rest[0];
  const agent = flag('as', rest);
  const lesson = flag('lesson', rest);
  if (!id || !agent || !lesson) {
    console.error('usage: task fail <id> --as agent-N --lesson "one-line gotcha"');
    console.error('  the --lesson field is mandatory; future bidders read it before claiming similar tasks');
    process.exit(2);
  }
  const r = withLock(() => {
    const data = loadTasks();
    const t = findTask(data, id);
    if (t.status !== 'claimed') return { ok:false, msg: `✗ ${id} is ${t.status}` };
    if (t.claimed_by !== agent)  return { ok:false, msg: `✗ ${id} claimed by ${t.claimed_by}, not ${agent}` };
    t.status = 'failed'; t.completed_at = new Date().toISOString(); t.lessons = lesson;
    // re-open for someone else to retry, but keep the lesson trace
    t.status = 'open'; t.claimed_by = null; t.claimed_at = null;
    saveTasks(data);
    return { ok:true };
  });
  if (!r.ok) { console.error(r.msg); process.exit(1); }
  console.log(col(`✗ ${id} failed by ${agent} — re-opened with lesson`, 'failed'));
  console.log(col(`  📓 lesson recorded: ${lesson}`, 'dim'));
  console.log(col(`  also post a [LESSON] entry to blackboard.md (see CLAUDE.md step 6)`, 'dim'));
}

function cmdLessons() {
  const data = loadTasks();
  const filter = flag('for', rest);
  const lessons = data.tasks
    .filter(t => t.lessons)
    .filter(t => !filter || reqs(t).includes(filter))
    .slice(-10);
  if (lessons.length === 0) {
    console.log(col('  no prior lessons recorded' + (filter ? ` for ${filter}` : ''), 'dim'));
    return;
  }
  console.log(col('  Recent lessons (read before claiming similar tasks):', 'bold'));
  for (const t of lessons) {
    console.log(`  ${col(t.id, 'dim')} [${reqs(t).join(',')}]  ${t.lessons}`);
  }
}

function cmdAdd() {
  const title = rest[0];
  const requires = (flag('requires', rest) || flag('needs', rest) || '').split(',').filter(Boolean);
  const estimate = parseInt(flag('estimate', rest) || '3', 10);
  if (!title) { console.error('usage: task add "title" --requires tag[,tag]'); process.exit(2); }
  withLock(() => {
    const data = loadTasks();
    const n = data.tasks.length + 1;
    const id = 'T-' + String(n).padStart(2, '0');
    data.tasks.push({
      id, title, requires, estimate_min: estimate,
      output: `project/output/${id}.md`,
      status: 'open', claimed_by: null, claimed_at: null,
      completed_at: null, result: null, lessons: null,
    });
    saveTasks(data);
    console.log(col(`✓ added ${id}`, 'done'));
  });
}

function cmdStatus() {
  const data = loadTasks();
  const counts = { open: 0, claimed: 0, done: 0, failed: 0 };
  for (const t of data.tasks) counts[t.status] = (counts[t.status] || 0) + 1;
  console.log(`tasks: ${col(counts.open + ' open', 'open')} · ${col(counts.claimed + ' claimed', 'claimed')} · ${col(counts.done + ' done', 'done')} · ${col(counts.failed + ' failed', 'failed')}`);
  const withLessons = data.tasks.filter(t => t.lessons).length;
  if (withLessons) console.log(col(`📓 ${withLessons} tasks have lessons recorded`, 'dim'));
}

const dispatch = { list: cmdList, claim: cmdClaim, done: cmdDone, fail: cmdFail, lessons: cmdLessons, add: cmdAdd, status: cmdStatus };
const fn = dispatch[cmd];
if (!fn) {
  console.error('usage: task <list|claim|done|fail|lessons|add|status> [args]');
  console.error('  list     [--mine agent-N] [--open]');
  console.error('  claim    <id> --as agent-N');
  console.error('  done     <id> --as agent-N --result "summary"');
  console.error('  fail     <id> --as agent-N --lesson "one-line gotcha"');
  console.error('  lessons  [--for <tag>]   # recent failure traces');
  console.error('  add      "<title>" --requires tag[,tag]');
  console.error('  status');
  process.exit(2);
}
fn();
